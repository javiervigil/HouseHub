{"ast":null,"code":"import apiService from '@/service/apiService';\nimport { ref } from 'vue';\nimport TableBar from '@/components/TableBar.vue';\nimport { Button, Column, DataTable, Dialog, InputText, Toast } from 'primevue';\nimport { Form } from '@primevue/forms';\nimport { useToast } from 'primevue/usetoast';\nexport default {\n  components: {\n    DataTable,\n    Column,\n    TableBar,\n    Dialog,\n    InputText,\n    Button,\n    Form,\n    Toast\n  },\n  data() {\n    return {\n      toast: useToast(),\n      selectedItems: ref([]),\n      metaKey: ref(true),\n      items: ref([]),\n      showAdd: ref(false)\n    };\n  },\n  methods: {\n    async refreshTable() {\n      try {\n        const response = await apiService.getLotes();\n        this.items = response.data;\n      } catch (error) {\n        console.error(\"Failed to fetch Lotes:\", error);\n      }\n    },\n    addItem() {\n      this.showAdd = true;\n    },\n    editItem() {\n      alert(this.selectedItems.length);\n      if (this.selectedItems.length != 1) {\n        this.toast.add({\n          severity: 'error',\n          summary: 'Select only one item to edit.',\n          life: 3000\n        });\n      }\n    },\n    deleteItem() {}\n  },\n  mounted() {\n    this.refreshTable();\n  }\n};","map":{"version":3,"names":["apiService","ref","TableBar","Button","Column","DataTable","Dialog","InputText","Toast","Form","useToast","components","data","toast","selectedItems","metaKey","items","showAdd","methods","refreshTable","response","getLotes","error","console","addItem","editItem","alert","length","add","severity","summary","life","deleteItem","mounted"],"sources":["C:\\Java\\Projects\\myprimeview\\src\\views\\configuracion\\TipoLotes.vue"],"sourcesContent":["<template>\r\n    <Toast />\r\n    <div class=\"leftcontent\">\r\n        <TableBar @addItem=\"addItem\" @editItem=\"editItem\" @deleteItem=\"deleteItem\" @refreshTable=\"refreshTable\" />\r\n        <DataTable v-model:selection=\"selectedItems\" :value=\"items\" sortField=\"id\" stripedRows size=\"small\" paginator\r\n            :rows=\"10\" selectionMode=\"multiple\" :metaKeySelection=\"metaKey\" dataKey=\"id\" >\r\n            <Column selectionMode=\"multiple\" headerStyle=\"width: 3rem\"></Column>\r\n            <Column field=\"id\" header=\"Id\" sortable></Column>\r\n            <Column field=\"name\" header=\"name\" sortable></Column>\r\n            <Column field=\"name\" header=\"Name\" sortable></Column>\r\n            <Column field=\"description\" header=\"description\" sortable></Column>\r\n            <Column field=\"description\" header=\"description\" sortable></Column>\r\n        </DataTable>\r\n    </div>\r\n\r\n\r\n    <!-- add item -->\r\n    <Dialog v-model:visible=\"showAdd\" modal header=\"Agregar nuevo item\" :style=\"{ width: '25rem' }\">\r\n        <div class=\"form\">\r\n            <Form v-slot=\"$form\" v-bind:initialValues=\"initialValues\" v-bind:resolver=\"resolver\"\r\n                :validateOnValueUpdate=\"false\" :validateOnBlur=\"false\" @submit=\"onFormSubmit\"\r\n                class=\"flex flex-col gap-4 w-full sm:w-56\">\r\n                <div class=\"flex flex-col gap-1\">\r\n                    <InputText name=\"email\" type=\"email\" placeholder=\"email\" fluid />\r\n                    <Message v-if=\"$form.email?.invalid\" severity=\"error\" size=\"small\" variant=\"simple\">{{\r\n                        $form.email.error.message }}</Message>\r\n                </div>\r\n                <div class=\"flex flex-col gap-1\">\r\n                    <InputText name=\"password\" type=\"password\" placeholder=\"Password\" fluid />\r\n                    <Message v-if=\"$form.password?.invalid\" severity=\"error\" size=\"small\" variant=\"simple\">{{\r\n                        $form.password.error.message }}</Message>\r\n                </div>\r\n\r\n                <Message v-if=\"loginErr\" severity=\"error\" size=\"small\" variant=\"simple\">{{\r\n                    loginErr }}</Message>\r\n                <div class=\"formButtons\">\r\n                    <Button type=\"button\" label=\"Cancelar\" severity=\"secondary\" @click=\"showAdd = false\" style=\"margin-top: 20px;\"></Button>\r\n                    <Button type=\"button\" label=\"Guardar\" @click=\"showAdd = false\" style=\"margin-left: 20px;\"></Button>\r\n                </div>\r\n            </Form>\r\n        </div>\r\n    </Dialog>\r\n\r\n\r\n</template>\r\n\r\n<script>\r\n\r\nimport apiService from '@/service/apiService';\r\nimport { ref } from 'vue';\r\nimport TableBar from '@/components/TableBar.vue';\r\nimport { Button, Column, DataTable, Dialog, InputText, Toast } from 'primevue';\r\nimport { Form } from '@primevue/forms';\r\nimport { useToast } from 'primevue/usetoast';\r\n\r\nexport default {\r\n    components: {\r\n        DataTable, Column, TableBar, Dialog, InputText, Button, Form, Toast\r\n    },\r\n    data() {\r\n        return {\r\n            toast: useToast(),\r\n            selectedItems: ref([]),\r\n            metaKey: ref(true),\r\n            items: ref([]),\r\n            showAdd: ref(false),\r\n        }\r\n    },\r\n    methods: {\r\n        async refreshTable() {\r\n            try {\r\n                const response = await apiService.getLotes();\r\n                this.items = response.data;\r\n            } catch (error) {\r\n                console.error(\"Failed to fetch Lotes:\", error);\r\n            }\r\n        },\r\n        addItem() {\r\n            this.showAdd = true\r\n        },\r\n        editItem() {\r\n            alert(this.selectedItems.length)\r\n            if(this.selectedItems.length != 1){\r\n                this.toast.add({ severity: 'error', summary: 'Select only one item to edit.', life: 3000 });\r\n            }\r\n        },\r\n        deleteItem() {\r\n\r\n        }\r\n\r\n    },\r\n    mounted() {\r\n        this.refreshTable();\r\n    }\r\n}\r\n\r\n</script>\r\n\r\n<style scope>\r\n.leftcontent {\r\n 