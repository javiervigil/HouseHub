{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { Button, InputText, Message, Toast } from 'primevue';\nimport { Form } from '@primevue/forms';\nimport { ref } from 'vue';\nimport { useAuthStore } from '@/service/auth';\nimport { useRouter } from 'vue-router';\nimport { useToast } from 'primevue/usetoast';\nimport apiService from '@/service/apiService';\nexport default {\n  components: {\n    Button,\n    Form,\n    InputText,\n    Message,\n    Toast\n  },\n  data() {\n    return {\n      toast: useToast(),\n      authStore: useAuthStore(),\n      router: useRouter(),\n      token: ref(''),\n      loginErr: ref(''),\n      initialValues: {\n        email: 'jj@jj.com',\n        password: 'jj'\n      }\n    };\n  },\n  methods: {\n    async handleLogin() {\n      try {\n        const response = await apiService.login(this.initialValues.email, this.initialValues.password);\n        this.userData = response.data;\n        if (this.userData) {\n          this.toast.add({\n            severity: 'info',\n            summary: 'Dato login.' + this.userData.id,\n            life: 3000\n          });\n          console.log('this.userData ' + this.userData);\n          console.log('this.userData.id ' + this.userData.id);\n          this.userData = {\n            email: 'Usuario',\n            passwrd: 'user@example.com'\n          };\n          this.token = 'ejemplo-de-token-jwt';\n          this.authStore.login(this.userData, this.token);\n          return true;\n        } else {\n          return false;\n        }\n      } catch (error) {\n        console.error(\"Failed to login:\", error);\n      }\n    },\n    resolver({\n      values\n    }) {\n      const errors = {};\n      if (!values.email) {\n        errors.email = [{\n          message: 'Email is required.'\n        }];\n      }\n      if (!values.password) {\n        errors.password = [{\n          message: 'Password is required.'\n        }];\n      }\n      this.initialValues.email = values.email;\n      this.initialValues.password = values.password;\n      return {\n        errors\n      };\n    },\n    onFormSubmit({\n      valid\n    }) {\n      if (valid) {\n        this.handleLogin();\n        this.toast.add({\n          severity: 'info',\n          summary: 'this.authStore.isLoggedIn.' + this.authStore.isLoggedIn,\n          life: 3000\n        });\n        if (this.authStore.isLoggedIn) {\n          this.toast.add({\n            severity: 'success',\n            summary: 'Login successfully.',\n            life: 3000\n          });\n          this.$router.push({\n            name: 'home'\n          });\n        } else {\n          this.loginErr = 'User / password incorrect.';\n          this.toast.add({\n            severity: 'error',\n            summary: 'User / password incorrect.',\n            life: 3000\n          });\n        }\n      }\n    }\n  }\n};","map":{"version":3,"names":["Button","InputText","Message","Toast","Form","ref","useAuthStore","useRouter","useToast","apiService","components","data","toast","authStore","router","token","loginErr","initialValues","email","password","methods","handleLogin","response","login","userData","add","severity","summary","id","life","console","log","passwrd","error","resolver","values","errors","message","onFormSubmit","valid","isLoggedIn","$router","push","name"],"sources":["C:\\Java\\Projects\\myprimeview\\src\\views\\login\\Login.vue"],"sourcesContent":["<template>\r\n  <div class=\"main-content-login\">\r\n    <Toast />\r\n    <div class=\"login-container\">\r\n      <div class=\"login-image\">\r\n        <img src=\"@/assets/img8.jpg\" alt=\"Residential Pro\">\r\n      </div>\r\n      <div class=\"login-form\">\r\n        <h2>Iniciar Sesión</h2>\r\n        <Form v-slot=\"$form\" v-bind:initialValues=\"initialValues\" v-bind:resolver=\"resolver\"\r\n          :validateOnValueUpdate=\"false\" :validateOnBlur=\"false\" @submit=\"onFormSubmit\"\r\n          class=\"flex flex-col gap-4 w-full sm:w-56\">\r\n          <div class=\"flex flex-col gap-1\">\r\n            <InputText name=\"email\" type=\"email\" placeholder=\"email\" fluid />\r\n            <Message v-if=\"$form.email?.invalid\" severity=\"error\" size=\"small\" variant=\"simple\">{{\r\n              $form.email.error.message }}</Message>\r\n          </div>\r\n          <div class=\"flex flex-col gap-1\">\r\n            <InputText name=\"password\" type=\"password\" placeholder=\"Password\" fluid />\r\n            <Message v-if=\"$form.password?.invalid\" severity=\"error\" size=\"small\" variant=\"simple\">{{\r\n              $form.password.error.message }}</Message>\r\n          </div>\r\n\r\n          <Message v-if=\"loginErr\" severity=\"error\" size=\"small\" variant=\"simple\">{{\r\n            loginErr }}</Message>\r\n          <Button type=\"submit\" severity=\"secondary\" label=\"Submit\" style=\"margin-top: 20px;\" />\r\n        </Form>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { Button, InputText, Message, Toast } from 'primevue';\r\nimport { Form } from '@primevue/forms';\r\nimport { ref } from 'vue';\r\nimport { useAuthStore } from '@/service/auth';\r\nimport { useRouter } from 'vue-router';\r\nimport { useToast } from 'primevue/usetoast';\r\nimport apiService from '@/service/apiService';\r\n\r\nexport default {\r\n  components: {\r\n    Button, Form, InputText, Message, Toast\r\n  },\r\n  data() {\r\n    return {\r\n      toast: useToast(),\r\n      authStore: useAuthStore(),\r\n      router: useRouter(),\r\n      token: ref(''),\r\n      loginErr: ref(''),\r\n      initialValues: {\r\n        email: 'jj@jj.com',\r\n        password: 'jj'\r\n      },\r\n    }\r\n  },\r\n  methods: {\r\n    async handleLogin() {\r\n      try {\r\n        const response = await apiService.login(this.initialValues.email, this.initialValues.password);\r\n        this.userData = response.data;\r\n        if (this.userData) {\r\n          this.toast.add({ severity: 'info', summary: 'Dato login.' + this.userData.id, life: 3000 });\r\n          console.log('this.userData ' + this.userData);\r\n          console.log('this.userData.id ' + this.userData.id);\r\n          this.userData = { email: 'Usuario', passwrd: 'user@example.com' };\r\n          this.token = 'ejemplo-de-token-jwt';\r\n          this.authStore.login(this.userData, this.token);\r\n          return true;\r\n        }else{\r\n          return false;\r\n        }\r\n      } catch (error) {\r\n        console.error(\"Failed to login:\", error);\r\n      }\r\n    },\r\n\r\n    resolver({ values }) {\r\n      const errors = {};\r\n      if (!values.email) {\r\n        errors.email = [{ message: 'Email is required.' }];\r\n      }\r\n      if (!values.password) {\r\n        errors.password = [{ message: 'Password is required.' }];\r\n      }\r\n      this.initialValues.email = values.email;\r\n      this.initialValues.password = values.password;\r\n      return {\r\n        errors\r\n      };\r\n    },\r\n    onFormSubmit({ valid }) {\r\n      if (valid) {\r\n        this.handleLogin();\r\n        this.toast.add({ severity: 'info', summary: 'this.authStore.isLoggedIn.' + this.authStore.isLoggedIn, life: 3000 });\r\n        if (this.authStore.isLoggedIn) {\r\n          this.toast.add({ severity: 'success', summary: 'Login successfully.', life: 3000 });\r\n          this.$router.push({ name: 'home' });\r\n        } else {\r\n          this.loginErr = 'User / password incorrect.';\r\n          this.toast.add({ severity: 'error', summary: 'User / password incorrect.', life: 3000 });\r\n        }\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\ninput {\r\n  margin-bottom: 10px;\r\n  margin-top: 10px;\r\n}\r\n\r\n.login-container {\r\n  display: flex;\r\n  overflow: hidden;\r\n  max-width: 900px;\r\n  align-content: center;\r\n  align-items: center;\r\n  align-self: center;\r\n  border-radius: 10px;\r\n  background-color: white;\r\n  box-shadow: 0 5px 200px rgba(0, 0, 0, 0.1);\r\n  padding: 50px;\r\n}\r\n\r\n.login-image {\r\n  flex: 1;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  overflow: hidden;\r\n  border-radius: 20px;\r\n}\r\n\r\n.login-image img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n}\r\n\r\n.login-form {\r\n  flex: 1;\r\n  /* Le da al formulario el mismo peso flexible que la imagen */\r\n  padding: 40px;\r\n  display: flex;\r\n  flex-direction: column;\r\n  justify-content: center;\r\n}\r\n\r\n.main-content-login {\r\n  align-content: center;\r\n  align-items: center;\r\n  text-align: center;\r\n  align-self: center;\r\n  padding: 50px;\r\n  overflow-y: auto;\r\n  justify-content: space-between;\r\n  display: flex;\r\n  flex-direction: column;\r\n}\r\n</style>\r\n"],"mappings":";AAiCA,SAASA,MAAM,EAAEC,SAAS,EAAEC,OAAO,EAAEC,KAAI,QAAS,UAAU;AAC5D,SAASC,IAAG,QAAS,iBAAiB;AACtC,SAASC,GAAE,QAAS,KAAK;AACzB,SAASC,YAAW,QAAS,gBAAgB;AAC7C,SAASC,SAAQ,QAAS,YAAY;AACtC,SAASC,QAAO,QAAS,mBAAmB;AAC5C,OAAOC,UAAS,MAAO,sBAAsB;AAE7C,eAAe;EACbC,UAAU,EAAE;IACVV,MAAM;IAAEI,IAAI;IAAEH,SAAS;IAAEC,OAAO;IAAEC;EACpC,CAAC;EACDQ,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,KAAK,EAAEJ,QAAQ,CAAC,CAAC;MACjBK,SAAS,EAAEP,YAAY,CAAC,CAAC;MACzBQ,MAAM,EAAEP,SAAS,CAAC,CAAC;MACnBQ,KAAK,EAAEV,GAAG,CAAC,EAAE,CAAC;MACdW,QAAQ,EAAEX,GAAG,CAAC,EAAE,CAAC;MACjBY,aAAa,EAAE;QACbC,KAAK,EAAE,WAAW;QAClBC,QAAQ,EAAE;MACZ;IACF;EACF,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,WAAWA,CAAA,EAAG;MAClB,IAAI;QACF,MAAMC,QAAO,GAAI,MAAMb,UAAU,CAACc,KAAK,CAAC,IAAI,CAACN,aAAa,CAACC,KAAK,EAAE,IAAI,CAACD,aAAa,CAACE,QAAQ,CAAC;QAC9F,IAAI,CAACK,QAAO,GAAIF,QAAQ,CAACX,IAAI;QAC7B,IAAI,IAAI,CAACa,QAAQ,EAAE;UACjB,IAAI,CAACZ,KAAK,CAACa,GAAG,CAAC;YAAEC,QAAQ,EAAE,MAAM;YAAEC,OAAO,EAAE,aAAY,GAAI,IAAI,CAACH,QAAQ,CAACI,EAAE;YAAEC,IAAI,EAAE;UAAK,CAAC,CAAC;UAC3FC,OAAO,CAACC,GAAG,CAAC,gBAAe,GAAI,IAAI,CAACP,QAAQ,CAAC;UAC7CM,OAAO,CAACC,GAAG,CAAC,mBAAkB,GAAI,IAAI,CAACP,QAAQ,CAACI,EAAE,CAAC;UACnD,IAAI,CAACJ,QAAO,GAAI;YAAEN,KAAK,EAAE,SAAS;YAAEc,OAAO,EAAE;UAAmB,C