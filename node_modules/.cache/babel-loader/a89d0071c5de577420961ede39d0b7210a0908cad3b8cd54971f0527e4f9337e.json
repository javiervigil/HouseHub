{"ast":null,"code":"import { Button, InputText, Message, Select, Toast } from 'primevue';\nimport { Form } from '@primevue/forms';\nimport { ref } from 'vue';\nimport { useAuthStore } from '@/service/auth';\nimport { useRouter } from 'vue-router';\nimport { useToast } from 'primevue/usetoast';\nimport apiService from '@/service/apiService';\nexport default {\n  components: {\n    Button,\n    Form,\n    InputText,\n    Message,\n    Toast,\n    Select\n  },\n  data() {\n    return {\n      toast: useToast(),\n      authStore: useAuthStore(),\n      router: useRouter(),\n      token: ref(''),\n      loginErr: ref(''),\n      loginType: 0,\n      initialValues: ref({\n        email: 'jj@jj.com',\n        password: 'jj'\n      }),\n      selectedType: {\n        name: 'Usuario',\n        id: '1'\n      },\n      userTypes: [{\n        name: 'Usuario',\n        id: '1'\n      }, {\n        name: 'Administrador',\n        id: '2'\n      }]\n    };\n  },\n  methods: {\n    async handleLogin() {\n      try {\n        console.log('initialValues ' + JSON.stringify(this.initialValues));\n        console.log('loginType ' + this.loginType);\n        if (this.loginType === 1) {\n          //admin login          \n          const response = await apiService.loginAdmin(initialValues);\n        } else {\n          //normal login\n          const response = await apiService.loginUsers(initialValues);\n        }\n        this.userData = response.data;\n        if (this.userData) {\n          this.toast.add({\n            severity: 'info',\n            summary: 'Dato login.' + this.userData.id,\n            life: 3000\n          });\n          this.userData = {\n            email: 'Usuario',\n            passwrd: 'user@example.com'\n          };\n          this.token = 'ejemplo-de-token-jwt';\n          this.authStore.login(this.userData, this.token);\n          return true;\n        } else {\n          return false;\n        }\n      } catch (error) {\n        console.error(\"Failed to login:\", error);\n      }\n    },\n    resolver({\n      values\n    }) {\n      const errors = {};\n      if (!values.email) {\n        errors.email = [{\n          message: 'Email is required.'\n        }];\n      }\n      if (!values.password) {\n        errors.password = [{\n          message: 'Password is required.'\n        }];\n      }\n      this.initialValues.email = values.email;\n      this.initialValues.password = values.password;\n      return {\n        errors\n      };\n    },\n    onFormSubmit({\n      valid\n    }) {\n      if (valid) {\n        this.handleLogin();\n        this.toast.add({\n          severity: 'info',\n          summary: 'this.authStore.isLoggedIn.' + this.authStore.isLoggedIn,\n          life: 3000\n        });\n        if (this.authStore.isLoggedIn) {\n          this.toast.add({\n            severity: 'success',\n            summary: 'Login successfully.',\n            life: 3000\n          });\n          //this.$router.push({ name: 'home' });\n        } else {\n          this.loginErr = 'User / password incorrect.';\n          this.toast.add({\n            severity: 'error',\n            summary: 'User / password incorrect.',\n            life: 3000\n          });\n        }\n      }\n    }\n  }\n};","map":{"version":3,"names":["Button","InputText","Message","Select","Toast","Form","ref","useAuthStore","useRouter","useToast","apiService","components","data","toast","authStore","router","token","loginErr","loginType","initialValues","email","password","selectedType","name","id","userTypes","methods","handleLogin","console","log","JSON","stringify","response","loginAdmin","loginUsers","userData","add","severity","summary","life","passwrd","login","error","resolver","values","errors","message","onFormSubmit","valid","isLoggedIn"],"sources":["C:\\Java\\Projects\\HouseHub\\src\\views\\login\\Login.vue"],"sourcesContent":["<template>\r\n  <div class=\"main-content-login\">\r\n    <Toast />\r\n    <div class=\"login-container\">\r\n      <div class=\"login-image\">\r\n        <img src=\"@/assets/img8.jpg\" alt=\"Residential Pro\">\r\n      </div>\r\n      <div class=\"login-form\">\r\n        <h1>House Hub</h1>\r\n        <h3>Iniciar Sesión</h3>\r\n        <Form v-slot=\"$form\" v-bind:initialValues=\"initialValues\" v-bind:resolver=\"resolver\"\r\n          :validateOnValueUpdate=\"false\" :validateOnBlur=\"false\" @submit=\"onFormSubmit\"\r\n          class=\"flex flex-col gap-4 w-full sm:w-56\">\r\n\r\n          <div class=\"flex flex-col gap-1\">\r\n            <Select v-model=\"selectedType\" :options=\"userTypes\" optionLabel=\"name\" :loginType=\"loginType\" name=\"loginType\" fluid />\r\n          </div>\r\n\r\n          <div class=\"flex flex-col gap-1\">\r\n            <InputText name=\"email\" type=\"email\" placeholder=\"email\" fluid />\r\n            <Message v-if=\"$form.email?.invalid\" severity=\"error\" size=\"small\" variant=\"simple\">{{\r\n              $form.email.error.message }}</Message>\r\n          </div>\r\n          <div class=\"flex flex-col gap-1\">\r\n            <InputText name=\"password\" type=\"password\" placeholder=\"Password\" fluid />\r\n            <Message v-if=\"$form.password?.invalid\" severity=\"error\" size=\"small\" variant=\"simple\">{{\r\n              $form.password.error.message }}</Message>\r\n          </div>\r\n\r\n          <Message v-if=\"loginErr\" severity=\"error\" size=\"small\" variant=\"simple\">{{\r\n            loginErr }}</Message>\r\n          <Button type=\"submit\" severity=\"secondary\" label=\"Submit\" style=\"margin-top: 20px;\" />\r\n        </Form>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { Button, InputText, Message, Select, Toast } from 'primevue';\r\nimport { Form } from '@primevue/forms';\r\nimport { ref } from 'vue';\r\nimport { useAuthStore } from '@/service/auth';\r\nimport { useRouter } from 'vue-router';\r\nimport { useToast } from 'primevue/usetoast';\r\nimport apiService from '@/service/apiService';\r\n\r\nexport default {\r\n  components: {\r\n    Button, Form, InputText, Message, Toast, Select\r\n  },\r\n  data() {\r\n    return {\r\n      toast: useToast(),\r\n      authStore: useAuthStore(),\r\n      router: useRouter(),\r\n      token: ref(''),\r\n      loginErr: ref(''),\r\n      loginType: 0,\r\n      initialValues: ref({\r\n        email: 'jj@jj.com',\r\n        password: 'jj'\r\n      }),\r\n      selectedType: { name: 'Usuario', id: '1' },\r\n      userTypes: [\r\n        { name: 'Usuario', id: '1' },\r\n        { name: 'Administrador', id: '2' }\r\n      ]\r\n    }\r\n  },\r\n  methods: {\r\n    async handleLogin() {\r\n      try {\r\n        console.log('initialValues ' + JSON.stringify(this.initialValues));\r\n        console.log('loginType ' + this.loginType);\r\n        if(this.loginType ===1){//admin login          \r\n          const response = await apiService.loginAdmin(initialValues);\r\n        }else{//normal login\r\n          const response = await apiService.loginUsers(initialValues);\r\n        }\r\n        this.userData = response.data;\r\n        if (this.userData) {\r\n          this.toast.add({ severity: 'info', summary: 'Dato login.' + this.userData.id, life: 3000 });\r\n\r\n          this.userData = { email: 'Usuario', passwrd: 'user@example.com' };\r\n          this.token = 'ejemplo-de-token-jwt';\r\n          this.authStore.login(this.userData, this.token);\r\n          return true;\r\n        } else {\r\n          return false;\r\n        }\r\n      } catch (error) {\r\n        console.error(\"Failed to login:\", error);\r\n      }\r\n    },\r\n\r\n    resolver({ values }) {\r\n      const errors = {};\r\n      if (!values.email) {\r\n        errors.email = [{ message: 'Email is required.' }];\r\n      }\r\n      if (!values.password) {\r\n        errors.password = [{ message: 'Password is required.' }];\r\n      }\r\n      this.initialValues.email = values.email;\r\n      this.initialValues.password = values.password;\r\n      return {\r\n        errors\r\n      };\r\n    },\r\n    onFormSubmit({ valid }) {\r\n      if (valid) {\r\n        this.handleLogin();\r\n        this.toast.add({ severity: 'info', summary: 'this.authStore.isLoggedIn.' + this.authStore.isLoggedIn, life: 3000 });\r\n        if (this.authStore.isLoggedIn) {\r\n          this.toast.add({ severity: 'success', summary: 'Login successfully.', life: 3000 });\r\n          //this.$router.push({ name: 'home' });\r\n        } else {\r\n          this.loginErr = 'User / password incorrect.';\r\n          this.toast.add({ severity: 'error', summary: 'User / password incorrect.', life: 3000 });\r\n        }\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\ninput {\r\n  margin-bottom: 10px;\r\n  margin-top: 10px;\r\n}\r\n\r\n.login-container {\r\n  display: flex;\r\n  overflow: hidden;\r\n  max-width: 900px;\r\n  align-content: center;\r\n  align-items: center;\r\n  align-self: center;\r\n  border-radius: 10px;\r\n  background-color: white;\r\n  box-shadow: 0 5px 10px rgba(0, 0, 0, 0.1);\r\n  padding: 50px;\r\n}\r\n\r\n.login-image {\r\n  flex: 1;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  overflow: hidden;\r\n  border-radius: 20px;\r\n}\r\n\r\n.login-image img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n}\r\n\r\n.login-form {\r\n  flex: 1;\r\n  /* Le da al formulario el mismo peso flexible que la imagen */\r\n  padding: 40px;\r\n  display: flex;\r\n  flex-direction: column;\r\n  justify-content: center;\r\n}\r\n\r\n.main-content-login {\r\n  align-content: center;\r\n  align-items: center;\r\n  text-align: center;\r\n  align-self: center;\r\n  padding: 50px;\r\n  overflow-y: auto;\r\n  justify-content: space-between;\r\n  display: flex;\r\n  flex-direction: column;\r\n}\r\n</style>\r\n"],"mappings":"AAuCA,SAASA,MAAM,EAAEC,SAAS,EAAEC,OAAO,EAAEC,MAAM,EAAEC,KAAI,QAAS,UAAU;AACpE,SAASC,IAAG,QAAS,iBAAiB;AACtC,SAASC,GAAE,QAA