{"ast":null,"code":"import { Button, InputText, Message, Toast } from 'primevue';\nimport { Form } from '@primevue/forms';\nimport { ref } from 'vue';\nimport { useAuthStore } from '@/service/auth';\nimport { useRouter } from 'vue-router';\nimport { useToast } from 'primevue/usetoast';\nexport default {\n  components: {\n    Button,\n    Form,\n    InputText,\n    Message,\n    Toast\n  },\n  data() {\n    return {\n      toast: useToast(),\n      authStore: useAuthStore(),\n      router: useRouter(),\n      email: ref(''),\n      password: ref(''),\n      userData: ref(''),\n      token: ref(''),\n      loginErr: ref(''),\n      initialValues: {\n        email: '',\n        password: ''\n      }\n    };\n  },\n  methods: {\n    handleLogin() {\n      try {\n        const response = apiService.login();\n        this.userData = response.data;\n      } catch (error) {\n        console.error(\"Failed to login:\", error);\n      }\n      //this.userData = { email: 'Usuario', passwrd: 'user@example.com' };\n      this.token = 'ejemplo-de-token-jwt';\n      this.authStore.login(this.userData, this.token);\n      //this.$router.push('/');\n    },\n    resolver({\n      values\n    }) {\n      const errors = {};\n      if (!values.username) {\n        errors.username = [{\n          message: 'Username is required.'\n        }];\n      }\n      if (!values.firstName) {\n        errors.firstName = [{\n          message: 'First name is required.'\n        }];\n      }\n      if (!values.lastName) {\n        errors.lastName = [{\n          message: 'Last name is required.'\n        }];\n      }\n      return {\n        errors\n      };\n    },\n    onFormSubmit({\n      valid\n    }) {\n      console.log('valid ' + valid);\n      if (valid) {\n        this.handleLogin();\n        if (this.authStore.isLoggedIn) {\n          this.toast.add({\n            severity: 'success',\n            summary: 'Login successfully.',\n            life: 3000\n          });\n        } else {\n          this.loginErr = 'User / password incorrect.';\n        }\n      }\n    }\n  }\n};","map":{"version":3,"names":["Button","InputText","Message","Toast","Form","ref","useAuthStore","useRouter","useToast","components","data","toast","authStore","router","email","password","userData","token","loginErr","initialValues","methods","handleLogin","response","apiService","login","error","console","resolver","values","errors","username","message","firstName","lastName","onFormSubmit","valid","log","isLoggedIn","add","severity","summary","life"],"sources":["C:\\Java\\Projects\\myprimeview\\src\\views\\login\\Login.vue"],"sourcesContent":["<template>\r\n  <Toast />\r\n  <div class=\"login-container\">\r\n    <div class=\"login-image\">\r\n      <img src=\"@/assets/img8.jpg\" alt=\"Residential Pro\">\r\n    </div>\r\n    <div class=\"login-form\">\r\n      <h2>Iniciar Sesión</h2>\r\n      <Form v-slot=\"$form\" v-bind:initialValues=\"initialValues\" v-bind:resolver=\"resolver\"\r\n        :validateOnValueUpdate=\"false\" :validateOnBlur=\"false\" @submit=\"onFormSubmit\"\r\n        class=\"flex flex-col gap-4 w-full sm:w-56\">\r\n        <div class=\"flex flex-col gap-1\">\r\n          <InputText name=\"email\" type=\"email\" placeholder=\"email\" fluid />\r\n          <Message v-if=\"$form.email?.invalid\" severity=\"error\" size=\"small\" variant=\"simple\">{{\r\n            $form.email.error.message }}</Message>\r\n        </div>\r\n        <div class=\"flex flex-col gap-1\">\r\n          <InputText name=\"password\" type=\"password\" placeholder=\"Password\" fluid />\r\n          <Message v-if=\"$form.password?.invalid\" severity=\"error\" size=\"small\" variant=\"simple\">{{\r\n            $form.password.error.message }}</Message>\r\n        </div>\r\n\r\n        <Message v-if=\"loginErr\" severity=\"error\" size=\"small\" variant=\"simple\">{{\r\n          loginErr }}</Message>\r\n        <Button type=\"submit\" severity=\"secondary\" label=\"Submit\" style=\"margin-top: 20px;\" />\r\n      </Form>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { Button, InputText, Message, Toast } from 'primevue';\r\nimport { Form } from '@primevue/forms';\r\nimport { ref } from 'vue';\r\nimport { useAuthStore } from '@/service/auth';\r\nimport { useRouter } from 'vue-router';\r\nimport { useToast } from 'primevue/usetoast';\r\n\r\nexport default {\r\n  components: {\r\n    Button, Form, InputText, Message, Toast\r\n  },\r\n  data() {\r\n    return {\r\n      toast: useToast(),\r\n      authStore: useAuthStore(),\r\n      router: useRouter(),\r\n      email: ref(''),\r\n      password: ref(''),\r\n      userData: ref(''),\r\n      token: ref(''),\r\n      loginErr: ref(''),\r\n\r\n      initialValues: {\r\n        email: '',\r\n        password: ''\r\n      },\r\n\r\n    }\r\n  },\r\n  methods: {\r\n    handleLogin() {\r\n            try {\r\n                const response =  apiService.login();\r\n                this.userData = response.data;\r\n            } catch (error) {\r\n                console.error(\"Failed to login:\", error);\r\n            }\r\n      //this.userData = { email: 'Usuario', passwrd: 'user@example.com' };\r\n      this.token = 'ejemplo-de-token-jwt';\r\n      this.authStore.login(this.userData, this.token);\r\n      //this.$router.push('/');\r\n    },\r\n\r\n    resolver({ values }) {\r\n      const errors = {};\r\n\r\n      if (!values.username) {\r\n        errors.username = [{ message: 'Username is required.' }];\r\n      }\r\n\r\n      if (!values.firstName) {\r\n        errors.firstName = [{ message: 'First name is required.' }];\r\n      }\r\n\r\n      if (!values.lastName) {\r\n        errors.lastName = [{ message: 'Last name is required.' }];\r\n      }\r\n\r\n      return {\r\n        errors\r\n      };\r\n    },\r\n    onFormSubmit({ valid }) {\r\n      console.log('valid ' + valid);\r\n      if (valid) {\r\n        this.handleLogin();\r\n        if (this.authStore.isLoggedIn) {\r\n          this.toast.add({ severity: 'success', summary: 'Login successfully.', life: 3000 });\r\n        } else {\r\n          this.loginErr = 'User / password incorrect.';\r\n        }\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\ninput{\r\n    margin-bottom: 20px;\r\n}\r\n\r\n.login-container {\r\n  display: flex;\r\n  overflow: hidden;\r\n  max-width: 900px;\r\n  align-content: center;\r\n  align-items: center;\r\n  align-self: center;\r\n}\r\n\r\n.login-image {\r\n  flex: 1;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  overflow: hidden;\r\n  border-radius: 20px;\r\n}\r\n\r\n.login-image img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n}\r\n\r\n.login-form {\r\n  flex: 1;\r\n  /* Le da al formulario el mismo peso flexible que la imagen */\r\n  padding: 40px;\r\n  display: flex;\r\n  flex-direction: column;\r\n  justify-content: center;\r\n}\r\n</style>\r\n"],"mappings":"AA+BA,SAASA,MAAM,EAAEC,SAAS,EAAEC,OAAO,EAAEC,KAAI,QAAS,UAAU;AAC5D,SAASC,IAAG,QAAS,iBAAiB;AACtC,SAASC,GAAE,QAAS,KAAK;AACzB,SAASC,YAAW,QAAS,gBAAgB;AAC7C,SAASC,SAAQ,QAAS,YAAY;AACtC,SAASC,QAAO,QAAS,mBAAmB;AAE5C,eAAe;EACbC,UAAU,EAAE;IACVT,MAAM;IAAEI,IAAI;IAAEH,SAAS;IAAEC,OAAO;IAAEC;EACpC,CAAC;EACDO,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,KAAK,EAAEH,QAAQ,CAAC,CAAC;MACjBI,SAAS,EAAEN,YAAY,CAAC,CAAC;MACzBO,MAAM,EAAEN,SAAS,CAAC,CAAC;MACnBO,KAAK,EAAET,GAAG,CAAC,EAAE,CAAC;MACdU,QAAQ,EAAEV,GAAG,CAAC,EAAE,CAAC;MACjBW,QAAQ,EAAEX,GAAG,CAAC,EAAE,CAAC;MACjBY,KAAK,EAAEZ,GAAG,CAAC,EAAE,CAAC;MACda,QAAQ,EAAEb,GAAG,CAAC,EAAE,CAAC;MAEjBc,aAAa,EAAE;QACbL,KAAK,EAAE,EAAE;QACTC,QAAQ,EAAE;MACZ;IAEF;EACF,CAAC;EACDK,OAAO,EAAE;IACPC,WAAWA,CAAA,EAAG;MACN,IAAI;QACA,MAAMC,QAAO,GAAKC,UAAU,CAACC,KAAK,CAAC,CAAC;QACpC,IAAI,CAACR,QAAO,GAAIM,QAAQ,CAACZ,IAAI;MACjC,EAAE,OAAOe,KAAK,EAAE;QACZC,OAAO,CAACD,KAAK,CAAC,kBAAkB,EAAEA,KAAK,CAAC;MAC5C;MACN;MACA,IAAI,CAACR,KAAI,GAAI,sBAAsB;MACnC,IAAI,CAACL,SAAS,CAACY,KAAK,CAAC,IAAI,CAACR,QAAQ,EAAE,IAAI,CAACC,KAAK,CAAC;MAC/C;IACF,CAAC;