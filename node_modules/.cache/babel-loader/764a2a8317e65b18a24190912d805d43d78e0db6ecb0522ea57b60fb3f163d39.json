{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { Button, InputText, Message } from 'primevue';\nimport { Form } from '@primevue/forms';\nimport { ref } from 'vue';\nimport { useAuthStore } from '@/service/auth';\nimport { useRouter } from 'vue-router';\nimport { useToast } from 'primevue/toast';\nexport default {\n  components: {\n    Button,\n    Form,\n    InputText,\n    Message\n  },\n  data() {\n    return {\n      toast: useToast(),\n      authStore: useAuthStore(),\n      router: useRouter(),\n      username: ref(''),\n      password: ref(''),\n      userData: ref(''),\n      token: ref(''),\n      initialValues: {\n        username: '',\n        firstName: '',\n        lastName: ''\n      }\n    };\n  },\n  methods: {\n    handleLogin() {\n      // Aquí harías la llamada a tu API\n      // Si la autenticación es exitosa, llamas a la acción del store\n      this.userData = {\n        name: 'Usuario',\n        email: 'user@example.com'\n      };\n      this.token = 'ejemplo-de-token-jwt';\n      this.authStore.login(this.userData, this.token);\n      this.$router.push('/');\n    },\n    resolver({\n      values\n    }) {\n      errors = {};\n      if (!values.username) {\n        errors.username = [{\n          message: 'Username is required.'\n        }];\n      }\n      if (!values.name) {\n        errors.firstName = [{\n          message: 'First name is required.'\n        }];\n      }\n      if (!values.surname) {\n        errors.lastName = [{\n          message: 'Last name is required.'\n        }];\n      }\n      return {\n        errors\n      };\n    },\n    onFormSubmit({\n      valid\n    }) {\n      if (valid) {\n        toast.add({\n          severity: 'success',\n          summary: 'Form is submitted.',\n          life: 3000\n        });\n      }\n    }\n  }\n};","map":{"version":3,"names":["Button","InputText","Message","Form","ref","useAuthStore","useRouter","useToast","components","data","toast","authStore","router","