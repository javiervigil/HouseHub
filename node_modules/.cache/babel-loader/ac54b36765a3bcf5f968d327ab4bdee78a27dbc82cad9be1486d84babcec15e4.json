{"ast":null,"code":"import { Button, InputText, Message, Toast } from 'primevue';\nimport { Form } from '@primevue/forms';\nimport { ref } from 'vue';\nimport { useAuthStore } from '@/service/auth';\nimport { useRouter } from 'vue-router';\nimport { useToast } from 'primevue/usetoast';\nimport apiService from '@/service/apiService';\nexport default {\n  components: {\n    Button,\n    Form,\n    InputText,\n    Message,\n    Toast\n  },\n  data() {\n    return {\n      toast: useToast(),\n      authStore: useAuthStore(),\n      router: useRouter(),\n      token: ref(''),\n      loginErr: ref(''),\n      formData: {\n        email: '',\n        password: '`'\n      },\n      initialValues: {\n        email: 'jj@jj.com',\n        password: 'jj'\n      }\n    };\n  },\n  methods: {\n    async handleLogin(values) {\n      try {\n        console.log('antes de login ' + this.$form);\n        const response = await apiService.login(this.email, this.password);\n        console.log('hizo login ' + response);\n        this.userData = response.data;\n        //this.userData = { email: 'Usuario', passwrd: 'user@example.com' };\n        this.token = 'ejemplo-de-token-jwt';\n        this.authStore.login(this.userData, this.token);\n        //this.$router.push('/');\n      } catch (error) {\n        console.error(\"Failed to login:\", error);\n      }\n    },\n    resolver({\n      values\n    }) {\n      const errors = {};\n      if (!values.email) {\n        errors.email = [{\n          message: 'Email is required.'\n        }];\n      }\n      if (!values.password) {\n        errors.password = [{\n          message: 'Password is required.'\n        }];\n      }\n      return {\n        errors\n      };\n    },\n    onFormSubmit({\n      valid\n    }) {\n      if (valid) {\n        this.handleLogin();\n        if (this.authStore.isLoggedIn) {\n          this.toast.add({\n            severity: 'success',\n            summary: 'Login successfully.',\n            life: 3000\n          });\n        } else {\n          this.loginErr = 'User / password incorrect.';\n        }\n      }\n    }\n  }\n};","map":{"version":3,"names":["Button","InputText","Message","Toast","Form","ref","useAuthStore","useRouter","useToast","apiService","components","data","toast","authStore","router","token","loginErr","formData","email","password","initialValues","methods","handleLogin","values","console","log","$form","response","login","userData","error","resolver","errors","message","onFormSubmit","valid","isLoggedIn","add","severity","summary","life"],"sources":["C:\\Java\\Projects\\myprimeview\\src\\views\\login\\Login.vue"],"sourcesContent":["<template>\r\n  <Toast />\r\n  <div class=\"login-container\">\r\n    <div class=\"login-image\">\r\n      <img src=\"@/assets/img8.jpg\" alt=\"Residential Pro\">\r\n    </div>\r\n    <div class=\"login-form\">\r\n      <h2>Iniciar Sesión</h2>\r\n      <Form v-slot=\"$form\" v-bind:initialValues=\"initialValues\" v-bind:resolver=\"resolver\"\r\n        :validateOnValueUpdate=\"false\" :validateOnBlur=\"false\" @submit=\"onFormSubmit\"\r\n        class=\"flex flex-col gap-4 w-full sm:w-56\">\r\n        <div class=\"flex flex-col gap-1\">\r\n          <InputText class=\"pi pi-user\" name=\"email\" type=\"email\" placeholder=\"email\" fluid />\r\n          <Message v-if=\"$form.email?.invalid\" severity=\"error\" size=\"small\" variant=\"simple\">{{\r\n            $form.email.error.message }}</Message>\r\n        </div>\r\n        <div class=\"flex flex-col gap-1\">\r\n          <InputText name=\"password\" type=\"password\" placeholder=\"Password\" fluid />\r\n          <Message v-if=\"$form.password?.invalid\" severity=\"error\" size=\"small\" variant=\"simple\">{{\r\n            $form.password.error.message }}</Message>\r\n        </div>\r\n\r\n        <Message v-if=\"loginErr\" severity=\"error\" size=\"small\" variant=\"simple\">{{\r\n          loginErr }}</Message>\r\n        <Button type=\"submit\" severity=\"secondary\" label=\"Submit\" style=\"margin-top: 20px;\" />\r\n      </Form>\r\n    </div>\r\n  </div>\r\n\r\n</template>\r\n\r\n<script>\r\nimport { Button, InputText, Message, Toast } from 'primevue';\r\nimport { Form } from '@primevue/forms';\r\nimport { ref } from 'vue';\r\nimport { useAuthStore } from '@/service/auth';\r\nimport { useRouter } from 'vue-router';\r\nimport { useToast } from 'primevue/usetoast';\r\nimport apiService from '@/service/apiService';\r\n\r\nexport default {\r\n  components: {\r\n    Button, Form, InputText, Message, Toast\r\n  },\r\n  data() {\r\n    return {\r\n      toast: useToast(),\r\n      authStore: useAuthStore(),\r\n      router: useRouter(),\r\n      token: ref(''),\r\n      loginErr: ref(''),\r\n      formData: {\r\n        email: '',\r\n        password: '`'\r\n      },\r\n      initialValues: {\r\n        email: 'jj@jj.com',\r\n        password: 'jj'\r\n      },\r\n\r\n    }\r\n  },\r\n  methods: {\r\n    async handleLogin(values) {\r\n      try {\r\n        console.log('antes de login ' + this.$form);\r\n        const response = await apiService.login(this.email, this.password);\r\n        console.log('hizo login ' + response);\r\n\r\n        this.userData = response.data;\r\n        //this.userData = { email: 'Usuario', passwrd: 'user@example.com' };\r\n        this.token = 'ejemplo-de-token-jwt';\r\n        this.authStore.login(this.userData, this.token);\r\n        //this.$router.push('/');\r\n      } catch (error) {\r\n        console.error(\"Failed to login:\", error);\r\n      }\r\n    },\r\n\r\n    resolver({ values }) {\r\n      const errors = {};\r\n      if (!values.email) {\r\n        errors.email = [{ message: 'Email is required.' }];\r\n      }\r\n      if (!values.password) {\r\n        errors.password = [{ message: 'Password is required.' }];\r\n      }\r\n      return {\r\n        errors\r\n      };\r\n    },\r\n    onFormSubmit({ valid }) {\r\n      if (valid) {\r\n        this.handleLogin();\r\n        if (this.authStore.isLoggedIn) {\r\n          this.toast.add({ severity: 'success', summary: 'Login successfully.', life: 3000 });\r\n        } else {\r\n          this.loginErr = 'User / password incorrect.';\r\n        }\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\ninput {\r\n  margin-bottom: 10px;\r\n  margin-top: 10px;\r\n\r\n}\r\n\r\n.login-container {\r\n  display: flex;\r\n  overflow: hidden;\r\n  max-width: 900px;\r\n  align-content: center;\r\n  align-items: center;\r\n  align-self: center;\r\n}\r\n\r\n.login-image {\r\n  flex: 1;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  overflow: hidden;\r\n  border-radius: 20px;\r\n}\r\n\r\n.login-image img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n}\r\n\r\n.login-form {\r\n  flex: 1;\r\n  /* Le da al formulario el mismo peso flexible que la imagen */\r\n  padding: 40px;\r\n  display: flex;\r\n  flex-direction: column;\r\n  justify-content: center;\r\n}\r\n</style>\r\n"],"mappings":"AAgCA,SAASA,MAAM,EAAEC,SAAS,EAAEC,OAAO,EAAEC,KAAI,QAAS,UAAU;AAC5D,SAASC,IAAG,QAAS,iBAAiB;AACtC,SAASC,GAAE,QAAS,KAAK;AACzB,SAASC,YAAW,QAAS,gBAAgB;AAC7C,SAASC,SAAQ,QAAS,YAAY;AACtC,SAASC,QAAO,QAAS,mBAAmB;AAC5C,OAAOC,UAAS,MAAO,sBAAsB;AAE7C,eAAe;EACbC,UAAU,EAAE;IACVV,MAAM;IAAEI,IAAI;IAAEH,SAAS;IAAEC,OAAO;IAAEC;EACpC,CAAC;EACDQ,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,KAAK,EAAEJ,QAAQ,CAAC,CAAC;MACjBK,SAAS,EAAEP,YAAY,CAAC,CAAC;MACzBQ,MAAM,EAAEP,SAAS,CAAC,CAAC;MACnBQ,KAAK,EAAEV,GAAG,CAAC,EAAE,CAAC;MACdW,QAAQ,EAAEX,GAAG,CAAC,EAAE,CAAC;MACjBY,QAAQ,EAAE;QACRC,KAAK,EAAE,EAAE;QACTC,QAAQ,EAAE;MACZ,CAAC;MACDC,aAAa,EAAE;QACbF,KAAK,EAAE,WAAW;QAClBC,QAAQ,EAAE;MACZ;IAEF;EACF,CAAC;EACDE,OAAO,EAAE;IACP,MAAMC,WAAWA,CAACC,MAAM,EAAE;MACxB,IAAI;QACFC,OAAO,CAACC,GAAG,CAAC,iBAAgB,GAAI,IAAI,CAACC,KAAK,CAAC;QAC3C,MAAMC,QAAO,GAAI,MAAMlB,UAAU,CAACmB,KAAK,CAAC,IAAI,CAACV,KAAK,EAAE,IAAI,CAACC,QAAQ,CAAC;QAClEK,OAAO,CAACC,GAAG,CAAC,aAAY,GAAIE,QAAQ,CAAC;QAErC,IAAI,CAACE,QAAO,GAAIF,QAAQ,CAAChB,IAAI;QAC7B;QACA,IA