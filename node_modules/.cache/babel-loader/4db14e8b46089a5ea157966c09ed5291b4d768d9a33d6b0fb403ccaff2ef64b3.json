{"ast":null,"code":"import apiService from '@/service/apiService';\nimport { ref } from 'vue';\nimport TableBar from '@/components/TableBar.vue';\nimport { Button, Column, DataTable, Dialog, InputText, Message, Select, Toast } from 'primevue';\nimport { Form } from '@primevue/forms';\nimport { useToast } from 'primevue/usetoast';\nexport default {\n  components: {\n    DataTable,\n    Column,\n    TableBar,\n    Dialog,\n    InputText,\n    Button,\n    Form,\n    Select,\n    Message,\n    Toast\n  },\n  data() {\n    return {\n      titulo: ref(''),\n      toast: useToast(),\n      selectedItems: ref([]),\n      metaKey: ref(true),\n      items: ref([]),\n      itemsLoteTypes: ref([]),\n      showAdd: ref(false),\n      initialValues: {\n        id: 0,\n        name: '',\n        description: '',\n        lotetypeId: 0\n      }\n    };\n  },\n  methods: {\n    async getTiposLote() {\n      try {\n        const response = await apiService.getTiposLote();\n        this.itemsLoteTypes = response.data;\n      } catch (error) {\n        console.error(\"Failed to fetch Tipos de Lotes:\", error);\n      }\n    },\n    async refreshTable() {\n      try {\n        const response = await apiService.getLotes();\n        this.items = response.data;\n      } catch (error) {\n        console.error(\"Failed to fetch Lotes:\", error);\n      }\n    },\n    async updateLote() {\n      try {\n        await apiService.updateLote(this.initialValues);\n      } catch (error) {\n        console.error(\"Failed to update Lote:\", error);\n      }\n    },\n    addItem() {\n      this.titulo = 'Agregar nuevo lote';\n      this.getTiposLote();\n      this.initialValues.id = null;\n      this.initialValues.name = '';\n      this.initialValues.description = '';\n      this.initialValues.lotetypeId = null;\n      this.refreshTable();\n      this.showAdd = true;\n    },\n    editItem() {\n      if (this.selectedItems.length != 1) {\n        this.toast.add({\n          severity: 'error',\n          summary: 'Select only one item to edit.',\n          life: 3000\n        });\n      } else {\n        this.titulo = 'Actualizar lote';\n        this.getTiposLote();\n        this.initialValues = this.selectedItems[0];\n        this.showAdd = true;\n      }\n    },\n    deleteItem() {\n      if (this.selectedItems.length === 0) {\n        this.toast.add({\n          severity: 'error',\n          summary: 'Select at least one item to delete.',\n          life: 3000\n        });\n      } else {\n        this.toast.add({\n          severity: 'info',\n          summary: 'Borrando....',\n          life: 3000\n        });\n      }\n    },\n    //Para el form \n    resolver({\n      values\n    }) {\n      const errors = {};\n      if (!values.name) {\n        errors.name = [{\n          message: 'Name is required.'\n        }];\n      }\n      if (!values.description) {\n        errors.description = [{\n          message: 'Description is required.'\n        }];\n      }\n      if (!values.lotetypeId) {\n        errors.description = [{\n          message: 'Lote Type is required.'\n        }];\n      }\n      this.initialValues.name = values.name;\n      this.initialValues.description = values.description;\n      this.initialValues.lotetypeId = values.lotetypeId;\n      return {\n        errors\n      };\n    },\n    onFormSubmit({\n      valid\n    }) {\n      if (valid) {\n        this.updateLote();\n        this.toast.add({\n          severity: 'success',\n          summary: 'Lote actualizado correctamente.',\n          life: 3000\n        });\n        this.showAdd = false;\n        this.selectedItems = [];\n      } else {\n\n        //this.toast.add({ severity: 'error', summary: 'No se actualizaron los datos del lote.', life: 3000 });\n      }\n    }\n  },\n  mounted() {\n    this.refreshTable();\n  }\n};","map":{"version":3,"names":["apiService","ref","TableBar","Button","Column","DataTable","Dialog","InputText","Message","Select","Toast","Form","useToast","components","data","titulo","toast","selectedItems","metaKey","items","itemsLoteTypes","showAdd","initialValues","id","name","description","lotetypeId","methods","getTiposLote","response","error","console","refreshTable","getLotes","updateLote","addItem","editItem","length","add","severity","summary","life","deleteItem","resolver","values","errors","message","onFormSubmit","valid","mounted"],"sources":["C:\\Java\\Projects\\myprimeview\\src\\views\\configuracion\\Lotes.vue"],"sourcesContent":["<template>\r\n    <Toast />\r\n    <div class=\"leftcontent\">\r\n        <TableBar @addItem=\"addItem\" @editItem=\"editItem\" @deleteItem=\"deleteItem\" @refreshTable=\"refreshTable\" />\r\n        <DataTable v-model:selection=\"selectedItems\" :value=\"items\" sortField=\"id\" stripedRows size=\"small\" paginator\r\n            :rows=\"10\" selectionMode=\"multiple\" :metaKeySelection=\"metaKey\" dataKey=\"id\">\r\n            <Column selectionMode=\"multiple\" headerStyle=\"width: 3rem\"></Column>\r\n            <Column field=\"id\" header=\"Id\" hidden></Column>\r\n            <Column field=\"name\" header=\"Nombre\" sortable></Column>\r\n            <Column field=\"description\" header=\"Descripcion\" sortable></Column>\r\n            <Column field=\"lotetypeId.name\" header=\"Tipo\" sortable></Column>\r\n        </DataTable>\r\n    </div>\r\n\r\n\r\n    <!-- Add / Edit item -->\r\n    <Dialog v-model:visible=\"showAdd\" modal :header=\"titulo\" :style=\"{ width: '25rem' }\">\r\n        <div class=\"form\">\r\n            <Form v-slot=\"$form\" v-bind:initialValues=\"initialValues\" v-bind:resolver=\"resolver\"\r\n                :validateOnValueUpdate=\"false\" :validateOnBlur=\"false\" @submit=\"onFormSubmit\"\r\n                class=\"flex flex-col gap-4 w-full sm:w-56\">\r\n                <div class=\"flex flex-col gap-1\">\r\n                    <InputText name=\"name\" type=\"text\" placeholder=\"Nombre\" fluid />\r\n                    <Message v-if=\"$form.name?.invalid\" severity=\"error\" size=\"small\" variant=\"simple\">{{\r\n                        $form.name.error.message }}</Message>\r\n                </div>\r\n                <div class=\"flex flex-col gap-1\">\r\n                    <InputText name=\"description\" type=\"text\" placeholder=\"Descripcion\" fluid />\r\n                    <Message v-if=\"$form.description?.invalid\" severity=\"error\" size=\"small\" variant=\"simple\">{{\r\n                        $form.description.error.message }}</Message>\r\n                </div>\r\n\r\n                <Select name=\"lotetypeId\" :options=\"itemsLoteTypes\" optionLabel=\"name\" placeholder=\"Tipo de lote\" fluid />\r\n                <Message v-if=\"$form.lotetypeId?.invalid\" severity=\"error\" size=\"small\" variant=\"simple\">{{\r\n                    $form.lotetypeId.error.message }}</Message>\r\n\r\n                <div class=\"formButtons\">\r\n                    <Button type=\"button\" label=\"Cancelar\" severity=\"secondary\" @click=\"showAdd = false\"\r\n                        style=\"margin-top: 20px;\"></Button>\r\n                    <Button type=\"submit\" label=\"Guardar\" style=\"margin-left: 20px;\"></Button>\r\n                </div>\r\n            </Form>\r\n        </div>\r\n    </Dialog>\r\n\r\n\r\n</template>\r\n\r\n<script>\r\n\r\nimport apiService from '@/service/apiService';\r\nimport { ref } from 'vue';\r\nimport TableBar from '@/components/TableBar.vue';\r\nimport { Button, Column, DataTable, Dialog, InputText, Message, Select, Toast } from 'primevue';\r\nimport { Form } from '@primevue/forms';\r\nimport { useToast } from 'primevue/usetoast';\r\n\r\nexport default {\r\n    components: {\r\n        DataTable, Column, TableBar, Dialog, InputText, Button, Form, Select, Message, Toast\r\n    },\r\n    data() {\r\n        return {\r\n            titulo: ref(''),\r\n            toast: useToast(),\r\n            selectedItems: ref([]),\r\n            metaKey: ref(true),\r\n            items: ref([]),\r\n            itemsLoteTypes: ref([]),\r\n            showAdd: ref(false),\r\n            initialValues: {\r\n                id: 0,\r\n                name: '',\r\n                description: '',\r\n                lotetypeId: 0\r\n            },\r\n        }\r\n    },\r\n    methods: {\r\n        async getTiposLote() {\r\n            try {\r\n                const response = await apiService.getTiposLote();\r\n                this.itemsLoteTypes = response.data;\r\n            } catch (error) {\r\n                console.error(\"Failed to fetch Tipos de Lotes:\", error);\r\n            }\r\n        },\r\n        async refreshTable() {\r\n            try {\r\n                const response = await apiService.getLotes();\r\n                this.items = response.data;\r\n            } catch (error) {\r\n                console.error(\"Failed to fetch Lotes:\", error);\r\n            }\r\n        },\r\n        async updateLote() {\r\n            try {\r\n                await apiService.updateLote(this.initialValues);\r\n            } catch (error) {\r\n                console.error(\"Failed to update Lote:\", error);\r\n            }\r\n        },\r\n        addItem() {\r\n            this.titulo = 'Agregar nuevo lote';\r\n            this.getTiposLote();\r\n            this.initialValues.id = null;\r\n            this.initialValues.name = '';\r\n            this.initialValues.description = '';\r\n            this.initialValues.lotetypeId = null;\r\n            this.refreshTable();\r\n            this.showAdd = true;\r\n        },\r\n        editItem() {\r\n            if (this.selectedItems.length != 1) {\r\n                this.toast.add({ severity: 'error', summary: 'Select only one item to edit.', life: 3000 });\r\n            } else {\r\n                this.titulo = 'Actualizar lote';\r\n                this.getTiposLote();\r\n                this.initialValues = this.selectedItems[0];\r\n                this.showAdd = true;\r\n\r\n            }\r\n        },\r\n        deleteItem() {\r\n            if (this.selectedItems.length === 0) {\r\n                this.toast.add({ severity: 'error', summary: 'Select at least one item to delete.', life: 3000 });\r\n            } else {\r\n                this.toast.add({ severity: 'info', summary: 'Borrando....', life: 3000 });\r\n            }\r\n        },\r\n\r\n        //Para el form \r\n        resolver({ values }) {\r\n            const errors = {};\r\n            if (!values.name) {\r\n                errors.name = [{ message: 'Name is required.' }];\r\n            }\r\n            if (!values.description) {\r\n                errors.description = [{ message: 'Description is required.' }];\r\n            }\r\n            if (!values.lotetypeId) {\r\n                errors.description = [{ message: 'Lote Type is required.' }];\r\n            }\r\n\r\n\r\n            this.initialValues.name = values.name;\r\n            this.initialValues.description = values.description;\r\n            this.initialValues.lotetypeId = values.lotetypeId;\r\n            return {\r\n                errors\r\n            };\r\n        },\r\n        onFormSubmit({ valid }) {\r\n            if (valid) {\r\n                this.updateLote();\r\n                this.toast.add({ severity: 'success', summary: 'Lote actualizado correctamente.', life: 3000 });\r\n                this.showAdd = false;\r\n                this.selectedItems = [];\r\n            } else {\r\n\r\n                //this.toast.add({ severity: 'error', summary: 'No se actualizaron los datos del lote.', life: 3000 });\r\n\r\n            }\r\n        }\r\n    },\r\n    mounted() {\r\n        this.refreshTable();\r\n    }\r\n}\r\n\r\n</script>\r\n\r\n<style scope>\r\n.leftcontent {\r\n    width: 50%;\r\n}\r\n\r\ninput {\r\n    margin-bottom: 10px;\r\n    margin-top: 10px;\r\n}\r\n\r\n.formButtons {\r\n    align-items: center;\r\n    align-content: center;\r\n\r\n}\r\n</style>"],"mappings":"AAkDA,OAAOA,UAAS,MAAO,sBAAsB;AAC7C,SAAS